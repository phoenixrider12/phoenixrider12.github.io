@article{ali2024deep,
  abbr        = {ASOC},
  bibtex_show = {true},
  title       = {Deep Reinforcement Learning for Sim-to-Real Policy Transfer of VTOL-UAVs Offshore Docking Operations},
  author      = {Ali, Ali Mohamed and Gupta, Aryaman and Hashim, Hashim A.},
  journal     = {Applied Soft Computing},
  volume      = {162},
  pages       = {111843},
  year        = {2024},
  issn        = {1568-4946},
  doi         = {10.1016/j.asoc.2024.111843},
  html        = {https://www.sciencedirect.com/science/article/pii/S1568494624006173},
  code        = {https://github.com/phoenixrider12/drone_docking},
  preview     = {drone_docking.png},
  selected    = {true},
  abstract    = {This paper proposes a novel Reinforcement Learning (RL) approach for sim-to-real policy transfer of Vertical Take-Off and Landing Unmanned Aerial Vehicles (VTOL-UAV). The proposed approach is designed for VTOL-UAV landing on offshore docking stations in maritime operations. The landing procedure is decomposed into an approach phase, handled by a model-based control scheme, and a landing phase, where DRL agents are trained offline to learn the optimal docking policy. The JONSWAP spectrum model generates a wave model for each episode to enhance policy generalization for sim2real transfer. Numerical experiments show that the PPO agent learns efficient policies to land in uncertain environments, enhancing the likelihood of successful sim-to-real transfer.}
}

